# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smelite_hajj
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Backend Server
PORT=3001
HOST=127.0.0.1
BACKEND_URL=http://your-domain.com:3001

# JWT Secret (CHANGE THIS! — server refuses to start in production without it)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string

# CORS — comma-separated allowed origins
CORS_ORIGIN=https://smelitehajj.com,https://www.smelitehajj.com

# Node Environment
NODE_ENV=production
